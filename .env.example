# Copy this file to `.env.local` for local development.
# Server-only. Do not expose this key in client-side code.
OPENAI_API_KEY=

# Default model for the review route.
OPENAI_MODEL=gpt-4.1-mini

# Sepolia deployment. Use a funded throwaway deployer key, never a main wallet.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
SEPOLIA_PRIVATE_KEY=0xYOUR_FUNDED_DEPLOYER_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Filled after deploying SmartJobsEscrow.
NEXT_PUBLIC_SMARTJOBS_ESCROW_ADDRESS=

# Swarm backend upload + retrieval.
# Recommended quickstart for the hackathon gateway:
# SWARM_BEE_API_URL=https://bzz.limo
# SWARM_POSTAGE_BATCH_ID=NULL_STAMP
# SWARM_GATEWAY_URL=https://bzz.limo
# NEXT_PUBLIC_SWARM_GATEWAY_URL=https://bzz.limo
#
# For your own Bee node instead, point this at a Bee API endpoint that can upload.
SWARM_BEE_API_URL=http://127.0.0.1:1633
# Use a usable postage batch with enough remaining capacity.
# When using https://bzz.limo with bee-js, set this to NULL_STAMP and the gateway
# will rewrite it to a valid batch ID for you.
SWARM_POSTAGE_BATCH_ID=YOUR_SWARM_POSTAGE_BATCH_ID
# Gateway used for retrieval and client-visible download links.
SWARM_GATEWAY_URL=http://127.0.0.1:1633
NEXT_PUBLIC_SWARM_GATEWAY_URL=http://127.0.0.1:1633
# Optional upload behavior.
SWARM_UPLOAD_PIN=true
SWARM_UPLOAD_DEFERRED=false
# Optional ACT (Access Control Trie) upload mode.
# Leave disabled for the default immutable public upload flow.
SWARM_ACT=false
SWARM_ACT_HISTORY_ADDRESS=
